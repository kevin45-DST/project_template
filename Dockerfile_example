# =====
# Image 
# ===== 
FROM <image>:<tag> AS <stage_name> 

# Exemple : 
# FROM python:3.12-slim AS api 
# FROM node:22-alpine AS frontend 
# FROM eclipse-temurin:21-jdk AS backend

# ================= 
# Working directory 
# ================= 
WORKDIR /<working_directory>

# ================ 
# Copy application 
# ================ 
COPY <source_dir>/ ./<destination_dir>/ COPY <config_file> . 
COPY <requirements_file> . 
COPY <entrypoint_file> . 

# Optional resources 
COPY <dataset_dir> . 
COPY <models_dir> . 
COPY <artifacts_dir> . 
COPY <metrics_dir> . 
COPY <assets_dir> . 
COPY <secrets_file> . 
COPY <extra_file> .

# ======================= 
# Install system packages 
# =======================
RUN apt-get update && apt-get install -y \ 
	<package_1> \ 
	<package_2> \ 
&& rm -rf /var/lib/apt/lists/*
 
# ============================
# Install project dependencies 
# ============================ 
RUN <package_manager_update_command> 

# Exemples : 
# RUN pip install --upgrade pip 
# RUN npm install -g npm 

RUN apk update RUN <dependency_install_command>
 
# Exemples : 
# RUN pip install --no-cache-dir -r requirements.txt 
# RUN npm ci # RUN mvn clean install

# ===================== 
# Build step (optional) 
# ===================== 
#RUN <build_command> 

# Exemples : 
# RUN npm run build 
# RUN python scripts/train.py 
# RUN make build

# ================================ 
# Environment variables (optional) 
# ================================ 
#ENV <KEY>=<VALUE>

# =========== 
# Expose port 
# ===========
EXPOSE <port>

# =============== 
# Default command 
# ===============
CMD ["<command>", "<arg1>", "<arg2>"] 

# Exemples : 
# CMD ["python", "main.py"] 
# CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8000"] 
# CMD ["gunicorn", "-w", "4", "-k", "uvicorn.workers.UvicornWorker", "src.main:app"] 
# CMD ["npm", "start"]
